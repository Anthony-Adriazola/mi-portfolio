---
import GitHub from "./icons/GitHub.astro"
import Tailwind from "./icons/Tailwind.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"

const TAGS = {
  ANGULAR: {
    name: "Angular",
    class: "bg-[#c3002f] text-white",
    icon: null,
  },
  DOTNET: {
    name: ".NET / C#",
    class: "bg-[#512bd4] text-white",
    icon: null,
  },
  TYPESCRIPT: {
    name: "TypeScript",
    class: "bg-[#007acc] text-white",
    icon: null,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  SQLSERVER: {
    name: "SQL Server",
    class: "bg-[#a91d22] text-white",
    icon: null,
  },
  RAZOR: {
    name: "Razor / C#",
    class: "bg-[#512bd4] text-white",
    icon: null,
  },
  HTML: {
    name: "HTML / CSS",
    class: "bg-[#e34f26] text-white",
    icon: null,
  },
}
const PROJECTS: {
  title: string
  description: string
  tags: { name: string; class: string; icon: any }[]
  image?: string
  link?: string
  github?: string
}[] = [
  {
    title: "Calculadora de Redes",
    description:
      "Calculadora de redes para subnetting y direccionamiento IP desarrollada con C# y Razor Pages. Permite calcular subredes, máscaras, direcciones de red, broadcast y rango de hosts. Interfaz responsive con HTML y CSS.",
    tags: [TAGS.DOTNET, TAGS.RAZOR, TAGS.HTML],
    link: "https://calculadora-redes-v7m3.onrender.com/",
  },
]
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
  {image && (
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
        <a href={`${import.meta.env.BASE_URL}${image}`} target="_blank" rel="noopener" class="block w-full">
          <div class="overflow-hidden rounded-2xl shadow-lg bg-white/50 flex items-center justify-center">
            <img
              alt={title}
              class="w-full h-auto max-h-80 md:max-h-96 lg:max-h-[480px] object-contain"
              loading="lazy"
              src="/public/projects/image.webp"
            />
          </div>
        </a>
       
    </div>
  </div>
  )}

  <div class={`w-full md:max-w-lg ${image ? "md:w-1/2" : ""}`}>
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row flex-wrap mb-2 gap-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                {tag.icon && <tag.icon class="size-4" />}
                {tag.name}
              </span>
            </li>
          ))}
        </ul>

      <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
      <footer class="flex items-end justify-start mt-4 gap-x-4">
          {github && (
            <LinkButton href={github}>
              <GitHub class="size-6" />
              Code
            </LinkButton>
          )}
          {link && (
            <LinkButton href={link}>
              <Link class="size-4" />
              Preview
            </LinkButton>
          )}
        </footer>
    </div>
  </div>
</article>
    ))
  }
</div>



